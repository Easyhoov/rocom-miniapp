/* 全局样式 — 沿用 Web 版紫蓝主题 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  background: linear-gradient(180deg, #e8f0fe 0%, #f5f0ff 50%, #fff 100%);
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  color: #1a1a2e;
  font-size: 28rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, .06);
  margin-bottom: 24rpx;
}

/* 主按钮 */
.btn-primary {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border: none;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

/* 输入框 */
.input {
  width: 100%;
  padding: 24rpx;
  border: 3rpx solid #e8e8e8;
  border-radius: 20rpx;
  font-size: 34rpx;
  font-weight: 500;
  background: #fafafa;
  box-sizing: border-box;
}

.input:focus {
  border-color: #667eea;
  background: #fff;
}

/* 标签 */
.tag {
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  border: 3rpx solid #e8e8e8;
  background: #fff;
  color: #666;
  display: inline-block;
}

.tag.active {
  border-color: #667eea;
  background: #667eea;
  color: #fff;
}

/* 属性图标 */
.attr-icon {
  width: 36rpx;
  height: 36rpx;
  display: inline-block;
}

/* 安全区域适配 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
