/* pages/index/index.wxss — 暖杏 + 金色游戏风 */

/* 头部 */
.header {
  text-align: center;
  padding: 32rpx 0 24rpx;
}

.header-badge {
  display: inline-block;
  font-size: 22rpx;
  color: #8B6914;
  background: linear-gradient(135deg, #FFF3D6, #FFE8B8);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid rgba(255, 179, 71, 0.2);
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  color: #2D2016;
  display: block;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #B8956A;
  margin-top: 8rpx;
  display: block;
  letter-spacing: 2rpx;
}

/* 输入卡片 */
.input-card {
  position: relative;
  overflow: hidden;
}

.input-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.input-group {
  flex: 1;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #8B7355;
  margin-bottom: 10rpx;
  font-weight: 500;
}

/* 快捷填参 — 借鉴灵蛋所 */
.quick-fill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.quick-label {
  font-size: 22rpx;
  color: #B8956A;
}

.quick-btn {
  font-size: 22rpx;
  color: #FF8C42;
  background: #FFF5E6;
  padding: 8rpx 18rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(255, 140, 66, 0.2);
}

.quick-btn:active {
  background: #FFE8CC;
}

/* 筛选标签 */
.filter-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

/* R值提示 */
.r-tip-box {
  background: #FFF8EE;
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.r-tip-text {
  font-size: 22rpx;
  color: #B8956A;
}

/* 抖动动画 */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-12rpx); }
  50% { transform: translateX(12rpx); }
  75% { transform: translateX(-8rpx); }
}

.shake {
  animation: shake 0.3s ease;
}

/* 结果卡片 */
.result-card {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

/* 结果 tab */
.tabs {
  display: flex;
  background: #FFF5E6;
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 16rpx;
}

.tab {
  flex: 1;
  padding: 14rpx 0;
  text-align: center;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #B8956A;
  transition: 0.2s;
}

.tab.on {
  background: #fff;
  color: #2D2016;
  font-weight: 600;
  box-shadow: 0 2rpx 10rpx rgba(180, 140, 80, 0.12);
}

.tab-n {
  font-weight: 700;
  color: #FF8C42;
  margin-left: 4rpx;
}

/* R 值显示 */
.r-display {
  text-align: center;
  font-size: 22rpx;
  color: #FF8C42;
  font-weight: 600;
  margin-bottom: 16rpx;
}

/* 结果网格 — 2列 */
.result-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.pet-card {
  width: calc(50% - 10rpx);
  background: linear-gradient(145deg, #FFFCF7 0%, #FFF8EE 100%);
  border-radius: 24rpx;
  padding: 24rpx 16rpx 20rpx;
  text-align: center;
  border: 2rpx solid rgba(255, 200, 100, 0.12);
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.pet-card:nth-child(odd) {
  margin-right: 16rpx;
}

.pet-card:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.pet-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin: 0 auto 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.pet-icon {
  width: 80rpx;
  height: 80rpx;
}

.pet-emoji {
  font-size: 40rpx;
}

.pet-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #2D2016;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

.pet-tier-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 6rpx;
}

.pet-r-diff {
  font-size: 20rpx;
  color: #C4A872;
}

.pet-tier {
  font-size: 22rpx;
  font-weight: 600;
}

.pet-tier.exact {
  color: #FF8C42;
}

.pet-tier.tolerance1,
.pet-tier.tolerance2 {
  color: #E8A030;
}

.pet-tier.nearest {
  color: #C4A872;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #8B7355;
  display: block;
  font-weight: 500;
}

.empty-hint {
  font-size: 24rpx;
  color: #C4A872;
  display: block;
  margin-top: 8rpx;
}

/* 页脚 */
.footer {
  text-align: center;
  padding: 32rpx 0 16rpx;
}

.footer-text {
  font-size: 20rpx;
  color: #C4A872;
  letter-spacing: 2rpx;
}
