/* pages/index/index.wxss */

.header {
  text-align: center;
  padding: 40rpx 0 32rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  margin-top: 8rpx;
  display: block;
}

/* 输入区域 */
.input-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.input-group {
  flex: 1;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 12rpx;
}

/* 筛选标签 */
.filter-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

/* R 值说明入口 */
.r-hint {
  text-align: center;
  margin-bottom: 20rpx;
}

.r-hint-text {
  font-size: 24rpx;
  color: #667eea;
}

/* 抖动动画 — 校验失败 */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-12rpx); }
  50% { transform: translateX(12rpx); }
  75% { transform: translateX(-8rpx); }
}

.shake {
  animation: shake 0.3s ease;
}

/* 结果 tab — 和原项目一致 */
.tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #888;
  transition: 0.2s;
}

.tab.on {
  background: #fff;
  color: #333;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, .08);
}

.tab-n {
  font-weight: 700;
  color: #667eea;
  margin-left: 4rpx;
}

/* R 值显示 */
.r-display {
  text-align: center;
  font-size: 20rpx;
  color: #7c4dff;
  font-weight: 500;
  margin-bottom: 16rpx;
}

/* 结果网格 — 2列 */
.result-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pet-card {
  width: calc(50% - 8rpx);
  background: #f8f9ff;
  border-radius: 24rpx;
  padding: 24rpx 16rpx 20rpx;
  text-align: center;
  border: 3rpx solid transparent;
  transition: 0.15s;
}

.pet-card:active {
  transform: scale(0.96);
}

.pet-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin: 0 auto 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.pet-icon {
  width: 76rpx;
  height: 76rpx;
}

.pet-emoji {
  font-size: 40rpx;
}

.pet-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

.pet-tier-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  margin-top: 4rpx;
}

.pet-r-diff {
  font-size: 20rpx;
  color: #bbb;
}

.pet-tier {
  font-size: 22rpx;
  font-weight: 500;
}

.pet-tier.exact {
  color: #7c4dff;
}

.pet-tier.tolerance1,
.pet-tier.tolerance2 {
  color: #ff6d00;
}

.pet-tier.nearest {
  color: #bbb;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #ccc;
  display: block;
}

/* R 值说明弹窗 */
.tip {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, .4);
  z-index: 100;
  justify-content: center;
  align-items: center;
}

.tip.on {
  display: flex;
}

.tip-box {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx;
  width: 85%;
  max-width: 640rpx;
}

.tip-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 24rpx;
}

.tip-body {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  white-space: pre-line;
}

.tip-btn {
  margin-top: 32rpx;
  width: 100%;
  padding: 20rpx;
  border: none;
  background: #667eea;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
}

/* 页脚 */
.footer {
  text-align: center;
  padding: 32rpx 0 16rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #bbb;
}
