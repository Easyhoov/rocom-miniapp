/* pages/index/index.wxss — 洛克手册风格 */

/* 头部 */
.header {
  padding: 20rpx 0 24rpx;
}

.header-title-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #2D2016;
  letter-spacing: 2rpx;
}

.header-sub {
  font-size: 24rpx;
  color: #B8956A;
  font-weight: 500;
}

/* 功能入口卡片 — 大入口 */
.feature-card {
  padding: 0;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.feature-main {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #3D3528 0%, #5A4D3A 100%);
  border-radius: 32rpx;
}

.feature-icon-large {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: rgba(255, 179, 71, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.feature-text {
  flex: 1;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFD699;
  display: block;
}

.feature-desc {
  font-size: 22rpx;
  color: rgba(255, 214, 153, 0.6);
  display: block;
  margin-top: 4rpx;
}

.feature-arrow {
  font-size: 36rpx;
  color: rgba(255, 214, 153, 0.4);
  margin-left: 12rpx;
}

/* 孵蛋查询卡片 */
.egg-card {
  position: relative;
  overflow: hidden;
}

.egg-card-header {
  margin-bottom: 20rpx;
}

.egg-card-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.egg-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2016;
}

.egg-card-desc {
  font-size: 22rpx;
  color: #B8956A;
  display: block;
  margin-top: 4rpx;
  margin-left: 36rpx;
}

/* 输入行 */
.input-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.input-group {
  flex: 1;
}

.input-label {
  display: block;
  font-size: 22rpx;
  color: #8B7355;
  margin-bottom: 8rpx;
  font-weight: 500;
}

/* 快捷填参 */
.quick-fill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.quick-label {
  font-size: 20rpx;
  color: #B8956A;
  flex-shrink: 0;
}

.quick-btn {
  font-size: 22rpx;
  color: #FF8C42;
  background: #FFF5E6;
  padding: 8rpx 16rpx;
  border-radius: 14rpx;
  border: 1.5rpx solid rgba(255, 140, 66, 0.15);
}

.quick-btn:active {
  background: #FFE8CC;
}

/* 筛选标签 */
.filter-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

/* R值提示 */
.r-tip {
  background: #FFF8EE;
  border-radius: 14rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 18rpx;
  text-align: center;
  font-size: 22rpx;
  color: #B8956A;
}

/* 抖动 */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-12rpx); }
  50% { transform: translateX(12rpx); }
  75% { transform: translateX(-8rpx); }
}
.shake { animation: shake 0.3s ease; }

/* 结果卡片 */
.result-card {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.result-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D2016;
}

.result-count {
  font-size: 22rpx;
  color: #B8956A;
}

/* Tab */
.tabs {
  display: flex;
  background: #FFF5E6;
  border-radius: 16rpx;
  padding: 5rpx;
  margin-bottom: 14rpx;
}

.tab {
  flex: 1;
  padding: 12rpx 0;
  text-align: center;
  border-radius: 14rpx;
  font-size: 24rpx;
  color: #B8956A;
}

.tab.on {
  background: #fff;
  color: #2D2016;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(180, 140, 80, 0.1);
}

.tab-n {
  font-weight: 700;
  color: #FF8C42;
  margin-left: 2rpx;
}

/* R值 */
.r-display {
  text-align: center;
  font-size: 22rpx;
  color: #FF8C42;
  font-weight: 600;
  margin-bottom: 14rpx;
}

/* 结果网格 */
.result-grid {
  display: flex;
  flex-wrap: wrap;
}

.pet-card {
  width: calc(50% - 8rpx);
  background: linear-gradient(145deg, #FFFCF7, #FFF8EE);
  border-radius: 20rpx;
  padding: 20rpx 14rpx 16rpx;
  text-align: center;
  border: 1.5rpx solid rgba(255, 200, 100, 0.1);
  box-sizing: border-box;
  margin-bottom: 12rpx;
}

.pet-card:nth-child(odd) {
  margin-right: 12rpx;
}

.pet-card:active {
  transform: scale(0.96);
}

.pet-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin: 0 auto 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.pet-img {
  width: 68rpx;
  height: 68rpx;
}

.pet-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #2D2016;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pet-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  margin-top: 4rpx;
}

.pet-rdiff {
  font-size: 18rpx;
  color: #C4A872;
}

.pet-pct {
  font-size: 20rpx;
  font-weight: 600;
  color: #E8A030;
}

.pet-pct.exact { color: #FF8C42; }
.pet-pct.tolerance1,
.pet-pct.tolerance2 { color: #E8A030; }
.pet-pct.nearest { color: #C4A872; }

/* 空状态 */
.empty {
  text-align: center;
  padding: 40rpx 0;
}
.empty-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 12rpx;
}
.empty-text {
  font-size: 26rpx;
  color: #B8956A;
}

/* 页脚 */
.footer {
  text-align: center;
  padding: 24rpx 0 12rpx;
}
.footer-text {
  font-size: 20rpx;
  color: #C4A872;
}
