/* pages/compendium/compendium.wxss — 洛克王国：世界 风格 */

/* 搜索栏 */
.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  padding: 22rpx 28rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(180, 140, 80, 0.06);
  box-sizing: border-box;
  border: 3rpx solid transparent;
  color: #2D2016;
}

.search-input:focus {
  border-color: #FFB347;
}

.search-input::placeholder {
  color: #C4A872;
}

/* 属性筛选 */
.attr-filter {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.attr-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  font-size: 26rpx;
  border-radius: 20rpx;
  border: 2rpx solid #F0E6D6;
  background: #fff;
  color: #8B7355;
}

.attr-item.active {
  background: #FFB347;
  border-color: #FFB347;
  color: #fff;
}

/* 结果统计 */
.result-info {
  font-size: 24rpx;
  color: #8B7355;
  margin-bottom: 16rpx;
}

/* 精灵列表 — 卡片行 */
.spirit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.spirit-row {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(180, 140, 80, 0.06);
  border: 2rpx solid rgba(180, 140, 80, 0.05);
}

.spirit-row:active {
  background: #FFFCF7;
  transform: scale(0.99);
}

/* 头像 */
.spirit-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF3D6, #FFE8CC);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
  overflow: hidden;
}

.spirit-img {
  width: 72rpx;
  height: 72rpx;
}

.spirit-placeholder {
  font-size: 40rpx;
}

/* 信息 */
.spirit-info {
  flex: 1;
  min-width: 0;
}

.spirit-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.spirit-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2016;
}

.attr-icon-small {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.shiny-dot {
  font-size: 24rpx;
}

.spirit-no {
  font-size: 22rpx;
  color: #C4A872;
  display: block;
  margin-top: 4rpx;
}

.spirit-range {
  font-size: 22rpx;
  color: #8B7355;
  display: block;
  margin-top: 4rpx;
}

/* 箭头 */
.arrow {
  font-size: 40rpx;
  color: #D0D8E0;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 加载状态 */
.load-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: #C4A872;
}

/* 错误重试 */
.error-retry {
  text-align: center;
  padding: 40rpx 0;
}

.error-text {
  font-size: 28rpx;
  color: #E74C3C;
  display: block;
  margin-bottom: 20rpx;
}

.retry-btn {
  display: inline-block;
  padding: 16rpx 40rpx;
  background: #FFB347;
  color: #fff;
  border-radius: 20rpx;
  font-size: 26rpx;
}
