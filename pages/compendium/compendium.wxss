/* pages/compendium/compendium.wxss — 匹配设计稿 */

/* 搜索栏 */
.search-bar {
  margin-bottom: 16rpx;
}

.search-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(180, 140, 80, 0.06);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  color: #2D2016;
}

.search-input:focus {
  border-color: #FFB347;
}

.search-input::placeholder {
  color: #D4C4A8;
}

/* 属性筛选 */
.attr-filter {
  white-space: nowrap;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.attr-item {
  display: inline-block;
  padding: 10rpx 22rpx;
  margin-right: 10rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid #F0E6D6;
  background: #FFFBF5;
  color: #8B7355;
}

.attr-item.active {
  background: linear-gradient(135deg, #FFB347, #FFCC80);
  border-color: #FFB347;
  color: #5D3A00;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(255, 179, 71, 0.2);
}

/* 精灵卡片 */
.spirit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.spirit-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(180, 140, 80, 0.06);
  border: 2rpx solid rgba(255, 200, 100, 0.08);
}

.spirit-card:active {
  background: #FFFCF7;
  transform: scale(0.99);
}

/* 头像 */
.spirit-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.spirit-img {
  width: 72rpx;
  height: 72rpx;
}

.spirit-placeholder {
  font-size: 40rpx;
}

/* 信息 */
.spirit-info {
  flex: 1;
  min-width: 0;
}

.spirit-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.spirit-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2016;
}

.attr-badge {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  background: #FFF3D6;
  color: #8B6914;
  font-weight: 500;
}

.shiny-dot {
  font-size: 24rpx;
}

.spirit-no {
  font-size: 22rpx;
  color: #C4A872;
  display: block;
  margin-top: 4rpx;
}

.spirit-range {
  font-size: 22rpx;
  color: #8B7355;
  display: block;
  margin-top: 4rpx;
}

/* 箭头 */
.arrow {
  font-size: 40rpx;
  color: #D4C4A8;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 加载状态 */
.load-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: #C4A872;
}

/* 错误重试 */
.error-retry {
  text-align: center;
  padding: 40rpx 0;
}

.error-text {
  font-size: 28rpx;
  color: #FF6B42;
  display: block;
  margin-bottom: 20rpx;
}

.retry-btn {
  display: inline-block;
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #FF8C42, #FFB347);
  color: #fff;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}
