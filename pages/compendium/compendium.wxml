<!--pages/compendium/compendium.wxml-->
<view class="page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="🔍 搜索精灵名称..." value="{{keyword}}"
           bindinput="onSearchInput" confirm-type="search" />
  </view>

  <!-- 属性筛选 -->
  <scroll-view class="attr-filter" scroll-x enable-flex>
    <view class="attr-item {{activeAttr === item.value ? 'active' : ''}}"
          wx:for="{{attributes}}" wx:key="value"
          bindtap="setAttribute" data-attr="{{item.value}}">
      {{item.emoji}} {{item.label}}
    </view>
  </scroll-view>

  <!-- 精灵列表 -->
  <view class="spirit-list">
    <view class="spirit-card" wx:for="{{items}}" wx:key="spirit_id"
          bindtap="goDetail" data-id="{{item.spirit_id}}">
      <!-- 圆形头像 -->
      <view class="spirit-avatar" style="background: {{item.attrBg}}">
        <image class="spirit-img" src="{{item.image}}" mode="aspectFit"
               lazy-load="{{true}}" wx:if="{{item.image}}" />
        <text class="spirit-placeholder" wx:else>{{item.attrEmoji}}</text>
      </view>

      <!-- 信息 -->
      <view class="spirit-info">
        <view class="spirit-name-row">
          <text class="spirit-name">{{item.base_name}}</text>
          <text class="attr-badge" wx:if="{{item.primary_attribute}}">{{item.primary_attribute}}</text>
          <text class="shiny-dot" wx:if="{{item.has_shiny_variant}}">✨</text>
        </view>
        <text class="spirit-no">{{item.spirit_no}}</text>
        <text class="spirit-range" wx:if="{{item.height_text}}">
          身高 {{item.height_text}} · 体重 {{item.weight_text}}
        </text>
      </view>

      <!-- 箭头 -->
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="load-more">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:elif="{{!hasMore && items.length > 0}}">已加载全部 ({{total}})</text>
    <text wx:elif="{{!loading && items.length === 0 && total === 0}}">没有找到匹配的精灵</text>
    <view wx:elif="{{loadError}}" class="error-retry">
      <text class="error-text">加载失败</text>
      <view class="retry-btn" bindtap="onPullDownRefresh">点击重试</view>
    </view>
  </view>
</view>
