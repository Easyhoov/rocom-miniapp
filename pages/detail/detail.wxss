/* pages/detail/detail.wxss — 洛克王国：世界 风格 */

/* 骨架屏 */
.skeleton {
  padding: 40rpx 0;
}

.sk-avatar {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #FFF3D6, #FFE8CC);
  border-radius: 32rpx;
  margin: 0 auto 32rpx;
}

.sk-line {
  height: 28rpx;
  background: #FFF5E6;
  border-radius: 14rpx;
  margin-bottom: 16rpx;
}

.sk-line.w60 { width: 60%; margin: 0 auto 16rpx; }
.sk-line.w40 { width: 40%; margin: 0 auto 16rpx; }

.sk-block {
  height: 200rpx;
  background: #FFF5E6;
  border-radius: 24rpx;
  margin-top: 32rpx;
}

/* 英雄区 */
.hero {
  text-align: center;
  padding: 20rpx 0;
  position: relative;
}

.hero-img {
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto;
}

.hero-placeholder {
  width: 300rpx;
  height: 300rpx;
  line-height: 300rpx;
  text-align: center;
  font-size: 120rpx;
  background: linear-gradient(135deg, #FFF3D6, #FFE8CC);
  border-radius: 32rpx;
  margin: 0 auto;
}

.shiny-badge {
  position: absolute;
  top: 20rpx;
  right: 40rpx;
  background: linear-gradient(135deg, #FFB74D, #FF9800);
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 183, 77, 0.3);
}

/* 名字行 */
.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.name {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D2016;
}

.attr-icon-detail {
  width: 40rpx;
  height: 40rpx;
  margin-left: 8rpx;
}

.attr-icon-detail.sub {
  opacity: 0.7;
}

.form-name {
  font-size: 26rpx;
  color: #8B7355;
  display: block;
}

.spirit-no {
  font-size: 24rpx;
  color: #C4A872;
  display: block;
  margin-top: 4rpx;
}

/* 特性 */
.trait {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #FFF5E6;
}

.trait-label {
  font-size: 22rpx;
  color: #C4A872;
}

.trait-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFB347;
  margin-left: 8rpx;
}

.trait-effect {
  font-size: 24rpx;
  color: #8B7355;
  display: block;
  margin-top: 8rpx;
  line-height: 1.6;
}

/* 数值 */
.stat-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
}

.stat-label {
  font-size: 22rpx;
  color: #C4A872;
  display: block;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2016;
  display: block;
  margin-top: 4rpx;
}

/* 种族值条 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2016;
  display: block;
  margin-bottom: 16rpx;
}

.race-bars {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.race-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.race-label {
  width: 80rpx;
  font-size: 22rpx;
  color: #8B7355;
  text-align: right;
}

.race-track {
  flex: 1;
  height: 16rpx;
  background: #FFF5E6;
  border-radius: 8rpx;
  overflow: hidden;
}

.race-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s ease;
}

.race-num {
  width: 50rpx;
  font-size: 22rpx;
  color: #FFB347;
  font-weight: 600;
}

/* 蛋组 */
.egg-groups {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.egg-tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: #FFF3D6;
  color: #FFB347;
  border-radius: 16rpx;
  font-weight: 500;
}

/* 进化链 */
.evo-chain {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  overflow-x: auto;
}

.evo-item {
  text-align: center;
  min-width: 140rpx;
  flex-shrink: 0;
}

.evo-item:active {
  opacity: 0.7;
}

.evo-img {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto;
}

.evo-name {
  font-size: 22rpx;
  color: #2D2016;
  font-weight: 500;
  display: block;
  margin-top: 4rpx;
}

.evo-level {
  font-size: 18rpx;
  color: #FFB347;
  display: block;
  margin-top: 2rpx;
}

/* 描述 */
.description {
  font-size: 26rpx;
  color: #8B7355;
  line-height: 1.8;
}

/* 操作按钮 */
.actions {
  margin-top: 24rpx;
}
